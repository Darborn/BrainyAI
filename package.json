{
    "name": "brainy_ai",
    "displayName": "BrainyAI",
    "version": "0.0.7",
    "description": "",
    "scripts": {
        "dev": "plasmo dev --src-path=.",
        "build": "plasmo build --src-path=.",
        "build:staging": "plasmo build --src-path=. --tag=staging",
        "package": "plasmo package --src-path=.",
        "lint": "npx eslint . --fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepare": "husky"
    },
    "dependencies": {
        "@ant-design/icons": "^5.6.1",
        "@headlessui/react": "^2.2.10",
        "@plasmohq/messaging": "^0.7.2",
        "@plasmohq/storage": "^1.9.3",
        "github-markdown-css": "^5.5.1",
        "globals": "^15.2.0",
        "highlight.js": "^11.11.1",
        "immutability-helper": "^3.1.1",
        "localforage": "^1.10.0",
        "markdown-it": "^14.1.0",
        "match-sorter": "^6.3.4",
        "moment": "^2.30.1",
        "plasmo": "0.90.5",
        "react": "18.3.1",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dom": "18.3.1",
        "react-router-dom": "^6.22.3",
        "remark-gfm": "^3.0.1",
        "sort-by": "^1.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.5",
        "@ianvs/prettier-plugin-sort-imports": "4.1.1",
        "@testing-library/jest-dom": "^7.0.0",
        "@testing-library/react": "^16.3.2",
        "@types/chrome": "0.0.268",
        "@types/markdown-it": "^14.1.1",
        "@types/node": "22.20.1",
        "@types/react": "18.3.31",
        "@types/react-dom": "18.3.7",
        "@vitest/coverage-v8": "^4.1.10",
        "antd": "^5.29.3",
        "autoprefixer": "^10.4.19",
        "eslint": "^9.39.5",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.0.11",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.1.0",
        "postcss": "^8.4.38",
        "prettier": "3.9.5",
        "tailwindcss": "^3.4.1",
        "typescript": "5.9.3",
        "typescript-eslint": "^8.65.0",
        "vitest": "^4.1.10"
    },
    "manifest": {
        "web_accessible_resources": [
            {
                "resources": [
                    "options.html",
                    "tabs/greeting.html",
                    "resources/**/*.json",
                    "resources/**/*.js"
                ],
                "matches": [
                    "<all_urls>"
                ]
            }
        ],
        "host_permissions": [
            "https://*/*",
            "wss://*/*"
        ],
        "action": {
            "default_title": "BrainyAI"
        },
        "permissions": [
            "declarativeNetRequest",
            "scripting",
            "tabs",
            "browsingData",
            "storage"
        ]
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{css,scss,json,md}": [
            "prettier --write"
        ]
    },
    "packageManager": "pnpm@8.15.4+sha256.cea6d0bdf2de3a0549582da3983c70c92ffc577ff4410cbf190817ddc35137c2"
}
